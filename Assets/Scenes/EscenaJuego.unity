--- !u!114 &208599201
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 208599197}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 790f5f591db8fc54298e47b7f6902199, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  interactionType: 0
  dialoguePanelUI: {fileID: 1216596158}
  dialogues:
  - sequenceId: 1
    interactionType: 0
    lines:
    - speaker: Flash
      text: "\xA1Bienvenido a La Rama compa\xF1ero! Te vamos a convertir en un verdadero
        bailar\xEDn."
    - speaker: Pinche
      text: "Eso requiere que sepa Bailar. \xBFC\xF3mo voy a aprender, lanz\xE1ndome?"
    - speaker: Flash
      text: "En tu caso, creo que aprender\xE1s mucho solo con ver a otros, pero
        debo ver como bailas ahora para saber con qu\xE9 estoy trabajando. \xA1Muestrame!"
    - speaker: Narrador
      text: Tu amigo Flash quiere ver tus pasos.
  - sequenceId: 2
    interactionType: 2
    lines:
    - speaker: Pinche
      text: No hay esperanza.
    - speaker: Flash
      text: "No digas eso, tienes una base solida de la que construir, y ahora que
        te mostr\xE9 unos pasos, podemos construir tu arsenal seductor."
    - speaker: Pinche
      text: "\xBFY ahora qu\xE9?"
    - speaker: Flash
      text: Me vas a ver aplicar mi conocimiento con una de las hermosas chicas presentes.
  - sequenceId: 3
    interactionType: 2
    lines:
    - speaker: Pinche
      text: Wow, eso fue increible... pero no puedo compararme
    - speaker: Flash
      text: No confias lo suficiente en tus habilidades amigo.
    - speaker: Flash
      text: "Quiz\xE1s hay alguien que pueda ayudar con eso: Busca a Fuego, un idiota
        colorido en chaqueta de cuero."
  dialogueIndex: 0
